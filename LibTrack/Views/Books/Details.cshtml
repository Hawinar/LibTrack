@model LibTrack.ViewModels.Entities.Books.BookDetailsViewModel

@{
    ViewData["Title"] = "Информация о книге";
}

<div class="card p-4">
    <div class="row g-5">
        <div class="col-md-4 text-center">
            <img src="~/uploads/Placeholder.png"
                 alt="@Model.Name"
                 class="book-image w-100" />
        </div>

        <div class="col-md-8">
            <div class="mb-4">
                <h1 class="mb-2">@Model.Name</h1>
                <p class="text-muted fs-5 mb-0">@Model.Author</p>
            </div>

            <div class="mb-4">
                <h5 class="text-muted mb-2">Описание</h5>
                <p>@Model.Description</p>
            </div>

            <div class="mb-4">
                <h5 class="text-muted mb-2">Год публикации</h5>
                <p class="mb-0">@Model.PublicationYear</p>
            </div>

            <div class="row g-4">
                <div class="col-md-6">
                    <h5 class="text-muted mb-2">Жанр</h5>
                    <p class="mb-0">@Model.Genre.Name</p>
                </div>

                <div class="col-md-6">
                    <h5 class="text-muted mb-2">Дата добавления</h5>
                    <p class="mb-0">@Model.AddDate.ToString("dd.MM.yyyy")</p>
                </div>

                <div class="col-md-6">
                    <h5 class="text-muted mb-2">Доступность</h5>

                    @if (Model.IsAvailable)
                    {
                        <span class="status-available">Доступна</span>
                    }
                    else
                    {
                        <span class="status-busy">Выдана</span>
                    }
                </div>
            </div>

            <div class="d-flex gap-2 mt-5">
                <a asp-action="Index" class="btn">
                    Назад
                </a>
            </div>
        </div>
    </div>
</div>