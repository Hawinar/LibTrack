@model RegisterRequest

@{
    ViewData["Title"] = "Регистрация";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card p-4">
            <div class="mb-4 text-center">
                <h1 class="mb-2">Регистрация</h1>

                <p class="text-muted mb-0">
                    Создайте аккаунт для работы с библиотекой
                </p>
            </div>

            <form asp-controller="Auth"
                  asp-action="Register"
                  method="post">

                @Html.AntiForgeryToken()

                <input type="hidden"
                       name="returnUrl"
                       value="@ViewBag.ReturnUrl" />

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3">
                </div>

                <div class="mb-4">
                    <label asp-for="FullName" class="form-label">
                        ФИО
                    </label>

                    <input asp-for="FullName"
                           type="text"
                           autocomplete="off"
                           placeholder="Введите ФИО"
                           class="form-control" />

                    <span asp-validation-for="FullName"
                          class="text-danger">
                    </span>
                </div>

                <div class="mb-4">
                    <label asp-for="Email" class="form-label">
                        Email
                    </label>

                    <input asp-for="Email"
                           type="email"
                           autocomplete="email"
                           placeholder="you@example.com"
                           class="form-control" />

                    <span asp-validation-for="Email"
                          class="text-danger">
                    </span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label">
                        Пароль
                    </label>

                    <input asp-for="Password"
                           type="password"
                           autocomplete="new-password"
                           placeholder="Введите пароль"
                           class="form-control" />

                    <span asp-validation-for="Password"
                          class="text-danger">
                    </span>
                </div>

                <div class="mb-4">
                    <label asp-for="RepeatPassword" class="form-label">
                        Повторите пароль
                    </label>

                    <input asp-for="RepeatPassword"
                           type="password"
                           autocomplete="off"
                           placeholder="Повторите пароль"
                           class="form-control" />

                    <span asp-validation-for="RepeatPassword"
                          class="text-danger">
                    </span>
                </div>

                <button type="submit" class="btn w-100">
                    Зарегистрироваться
                </button>
            </form>

            <div class="text-center mt-4">
                <span class="text-muted">
                    Уже есть аккаунт?
                </span>

                <a asp-controller="Auth"
                   asp-action="Login">
                    Войти
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}