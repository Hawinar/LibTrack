```cshtml id="r8wpzn"
@model LibTrack.ViewModels.Entities.BookUsers.BookUsersDetailsViewModel

@{
    ViewData["Title"] = "Редактирование выдачи";
}

<div class="card p-4">
    <h1 class="mb-4">Редактирование выдачи</h1>

    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly"
             class="text-danger mb-3">
        </div>

        <input type="hidden" asp-for="Id" />

        <div class="row g-4">
            <div class="col-md-6">
                <label asp-for="BookId" class="form-label"></label>
                <input asp-for="BookId" class="form-control" />
                <span asp-validation-for="BookId"
                      class="text-danger">
                </span>
            </div>

            <div class="col-md-6">
                <label asp-for="UserId" class="form-label"></label>
                <input asp-for="UserId" class="form-control" />
                <span asp-validation-for="UserId"
                      class="text-danger">
                </span>
            </div>

            <div class="col-md-6">
                <label asp-for="IssueDate" class="form-label"></label>
                <input asp-for="IssueDate" class="form-control" />
                <span asp-validation-for="IssueDate"
                      class="text-danger">
                </span>
            </div>

            <div class="col-md-6">
                <label asp-for="EstimatedReturnDate"
                       class="form-label">
                </label>

                <input asp-for="EstimatedReturnDate"
                       class="form-control" />

                <span asp-validation-for="EstimatedReturnDate"
                      class="text-danger">
                </span>
            </div>

            <div class="col-md-6">
                <label asp-for="ActualReturnDate"
                       class="form-label">
                </label>

                <input asp-for="ActualReturnDate"
                       class="form-control" />

                <span asp-validation-for="ActualReturnDate"
                      class="text-danger">
                </span>
            </div>

            <div class="col-md-6 d-flex align-items-center">
                <div class="form-check mt-4">
                    <input asp-for="Extented"
                           class="form-check-input" />

                    <label asp-for="Extented"
                           class="form-check-label">
                    </label>
                </div>
            </div>

            <div class="col-md-6">
                <label asp-for="Book" class="form-label"></label>
                <input asp-for="Book" class="form-control" />
                <span asp-validation-for="Book"
                      class="text-danger">
                </span>
            </div>

            <div class="col-md-6">
                <label asp-for="User" class="form-label"></label>
                <input asp-for="User" class="form-control" />
                <span asp-validation-for="User"
                      class="text-danger">
                </span>
            </div>
        </div>

        <div class="d-flex gap-2 mt-4">
            <input type="submit"
                   value="Сохранить"
                   class="btn" />

            <a asp-action="Index" class="btn">
                Назад
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
} 