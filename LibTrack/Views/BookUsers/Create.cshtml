@model LibTrack.ViewModels.Entities.BookUsers.BookUsersDetailsViewModel

@{
    ViewData["Title"] = "Создание выдачи";
}

<div class="card p-4">
    <h1 class="mb-4">Создание выдачи</h1>

    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly"
             class="text-danger mb-3">
        </div>

        <div class="row g-4">
            <div class="col-md-6">
                <label asp-for="BookId" class="form-label"></label>
                <input asp-for="BookId" class="form-control" />
                <span asp-validation-for="BookId"
                      class="text-danger">
                </span>
            </div>

            <div class="col-md-6">
                <label asp-for="UserId" class="form-label"></label>
                <input asp-for="UserId" class="form-control" />
                <span asp-validation-for="UserId"
                      class="text-danger">
                </span>
            </div>

            <input type="hidden" asp-for="IssueDate" />
            <input type="hidden" asp-for="EstimatedReturnDate" />
            <input type="hidden" asp-for="ActualReturnDate" />
            <input type="hidden" asp-for="Extented" />

            <div class="col-md-6" hidden="hidden">
                <label asp-for="Book" class="form-label"></label>
                <input asp-for="Book" class="form-control" />
                <span asp-validation-for="Book"
                      class="text-danger">
                </span>
            </div>

            <div class="col-md-6" hidden="hidden">
                <label asp-for="User" class="form-label"></label>
                <input asp-for="User" class="form-control" />
                <span asp-validation-for="User"
                      class="text-danger">
                </span>
            </div>
        </div>

        <div class="d-flex gap-2 mt-4">
            <input type="submit"
                   value="Создать"
                   class="btn" />

            <a asp-action="Index" class="btn">
                Назад
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}