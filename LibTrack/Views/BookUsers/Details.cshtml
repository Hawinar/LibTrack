@model LibTrack.ViewModels.Entities.BookUsers.BookUsersDetailsViewModel

@{
    ViewData["Title"] = "Информация о выдаче";
}

<div class="card p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="mb-1">Информация о выдаче</h1>

            <p class="text-muted mb-0">
                Данные о книге и пользователе
            </p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="mb-4">
                <h5 class="text-muted mb-2">Пользователь</h5>
                <p class="mb-0">@Model.User.FullName</p>
            </div>

            <div class="mb-4">
                <h5 class="text-muted mb-2">ID пользователя</h5>
                <p class="mb-0">@Model.UserId</p>
            </div>

            <div class="mb-4">
                <h5 class="text-muted mb-2">Дата выдачи</h5>
                <p class="mb-0">@Model.IssueDate</p>
            </div>

            <div class="mb-4">
                <h5 class="text-muted mb-2">
                    Планируемая дата возврата
                </h5>

                <p class="mb-0">
                    @Model.EstimatedReturnDate
                </p>
            </div>
        </div>

        <div class="col-md-6">
            <div class="mb-4">
                <h5 class="text-muted mb-2">
                    Фактическая дата возврата
                </h5>

                <p class="mb-0">
                    @Model.ActualReturnDate
                </p>
            </div>

            <div class="mb-4">
                <h5 class="text-muted mb-2">Продление</h5>
                <p class="mb-0">@(Model.Extented ? "Да" : "Нет")</p>
            </div>

            <div class="mb-4">
                <h5 class="text-muted mb-2">Книга</h5>

                <a asp-controller="Books"
                   asp-action="Details"
                   asp-route-id="@Model.BookId">

                    @Model.Book.Name

                </a>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 mt-4">
        <a asp-action="Edit"
           asp-route-id="@Model?.Id"
           class="btn">
            Редактировать
        </a>

        <a asp-action="Index" class="btn">
            Назад
        </a>
    </div>
</div>