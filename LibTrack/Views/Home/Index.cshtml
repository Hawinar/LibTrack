@model LibTrack.ViewModels.Entities.Books.BookIndexViewModel

@{
    ViewData["Title"] = "Библиотека | LibTrack";
}

<h1 class="mb-4">Новинки</h1>

<table class="table">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.Items[0].Name)</th>
            <th>@Html.DisplayNameFor(model => model.Items[0].Genre)</th>
            <th>@Html.DisplayNameFor(model => model.Items[0].Date)</th>
            <th>Изображение</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Name)</td>

                <td>@Html.DisplayFor(modelItem => item.Genre)</td>

                <td>@item.Date.ToString("dd.MM.yyyy")</td>

                <td>
                    <img src="~/uploads/Placeholder.png"
                         alt="@item.Name"
                         class="book-image" />
                </td>

                <td>
                    <a asp-controller="Books"
                       asp-action="Details"
                       asp-route-id="@item.Id"
                       class="btn">
                        Подробнее
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>