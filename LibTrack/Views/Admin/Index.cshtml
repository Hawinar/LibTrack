@model LibTrack.ViewModels.Entities.Books.BookIndexViewModel

@{
    ViewData["Title"] = "Панель администратора | LibTrack";
}

<h1>Панель администратора</h1>

<a asp-action="Create" asp-controller="Admin">Создать</a>


<form asp-action="Index" asp-controller="Books" method="get">
    <div>
        <label asp-for="Filter.Search"></label>
        <input asp-for="Filter.Search" />
    </div>

    <div>
        <label asp-for="Filter.GenreId"></label>
        <input asp-for="Filter.GenreId" type="number" />
    </div>

    <div>
        <label asp-for="Filter.OnlyAvailable"></label>
        <input asp-for="Filter.OnlyAvailable" />
    </div>

    <div>
        <label asp-for="Filter.SortBy"></label>
        <select asp-for="Filter.SortBy"
                asp-items="Html.GetEnumSelectList<BookSortBy>()">
        </select>
    </div>

    <div>
        <label asp-for="Filter.SortDirection"></label>
        <select asp-for="Filter.SortDirection"
                asp-items="Html.GetEnumSelectList<BookSortDirection>()">
        </select>
    </div>

    <button type="submit">Применить</button>

    <a asp-action="Index" asp-controller="Admin">Сбросить</a>
</form>

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Items[0].Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Items[0].Genre)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Items[0].Date)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Items)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Name)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Genre)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Date)
                </td>
                <td>
                    <a asp-controller="Admin"
                       asp-action="Details"
                       asp-route-id="@item.Id">
                        Details
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>

@{
    var prevDisabled = !Model.Items.HasPreviousPage ? "disabled" : "";
    var nextDisabled = !Model.Items.HasNextPage ? "disabled" : "";
}

<a asp-action="Index"
   asp-route-pageNumber="@(Model.Items.PageIndex - 1)"
   class="btn btn-default @prevDisabled">
    Previous
</a>
<a asp-action="Index"
   asp-route-pageNumber="@(Model.Items.PageIndex + 1)"
   class="btn btn-default @nextDisabled">
    Next
</a>