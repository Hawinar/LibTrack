@model LibTrack.ViewModels.Entities.Books.BookDetailsViewModel

@{
    ViewData["Title"] = "Добавление книги";
}

<div class="card p-4">
    <h1 class="mb-4">Добавление книги</h1>

    <form asp-action="Create" method="post" enctype="multipart/form-data">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <input type="hidden" asp-for="AddDate" />
        <input type="hidden" asp-for="UpdateDate" />
        <input type="hidden" asp-for="IsAvailable" />

        <div class="row g-4">
            <div class="col-md-6">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Author" class="form-label"></label>
                <input asp-for="Author" class="form-control" />
                <span asp-validation-for="Author" class="text-danger"></span>
            </div>

            <div class="col-12">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Genre" class="form-label"></label>
                <select asp-for="GenreId" asp-items="ViewBag.Genres" class="form-select"></select>
                <span asp-validation-for="Genre" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="ImageFile" class="form-label">Обложка книги</label>
                <input asp-for="ImageFile" type="file" class="form-control" />
                <span asp-validation-for="ImageFile" class="text-danger"></span>
            </div>
        </div>

        <div class="d-flex gap-2 mt-4">
            <input type="submit" value="Создать" class="btn" />

            <a asp-action="Index" class="btn">
                Назад
            </a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}